# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/?appName=Sarvavya

# Port the API listens on
PORT=5000

# Secret token required for admin (write) endpoints.
# Generate a long random value, e.g. with: openssl rand -hex 32
ADMIN_TOKEN=

# Allowed browser origin(s) for CORS (comma-separated). Leave blank in dev.
CLIENT_URL=http://localhost:3000
