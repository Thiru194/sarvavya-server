# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/?appName=Sarvavya

# Port the API listens on
PORT=5000

# --- JWT auth ---
# Secret used to sign admin login tokens.
# Generate a long random value, e.g. with: openssl rand -hex 32
JWT_SECRET=
# How long a login stays valid (e.g. 1d, 7d, 12h)
JWT_EXPIRES_IN=7d

# --- Seed admin (used by `npm run seed:admin`) ---
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@sarvavya.com
ADMIN_PASSWORD=change-this-password

# Legacy static token (no longer required once JWT auth is in use)
ADMIN_TOKEN=

# Allowed browser origin(s) for CORS (comma-separated). Leave blank in dev.
CLIENT_URL=http://localhost:3000
